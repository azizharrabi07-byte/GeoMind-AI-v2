{
  "name": "geomind-ai",
  "private": true,
  "version": "4.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently -k -n backend,frontend -c blue,green \"npm run backend\" \"wait-on http-get://127.0.0.1:3001/api/health -t 45000 && npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd backend && python -m uvicorn main:app --reload --host 127.0.0.1 --port 3001 --log-level info",
    "backend:check": "python -c \"import urllib.request; urllib.request.urlopen('http://127.0.0.1:3001/api/health', timeout=3); print('Backend OK')\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.21.0",
    "motion": "^12.23.24",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  }
}
